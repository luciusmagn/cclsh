#!/bin/sh
# Build the cclsh binary atomically: save-application writes cclsh.new
# and the rename below is atomic, so ./cclsh is always a complete
# executable even if a build is interrupted.
set -e
cd "$(dirname "$0")/.."
rm -f cclsh.new
ccl -n -b -e \
    '(handler-case
         (load "scripts/build.lisp")
       (serious-condition (condition)
         (format *error-output* "cclsh build loader failed: ~a~%" condition)
         (ccl:quit 1)))'
if [ ! -x cclsh.new ]; then
    echo "cclsh build: cclsh.new was not created" >&2
    exit 1
fi
mv -f cclsh.new cclsh
echo "Built ./cclsh"
